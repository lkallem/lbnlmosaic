title: {{SITE_TITLE}}
description: {{SITE_DESCRIPTION}}
baseurl: "{{SITE_BASEURL}}"
url: "{{SITE_URL}}"

# Legal/Funding Acknowledgment (appears in footer accordion)
# This section is configured during setup. To modify or disable:
# - Edit the text below, or comment out the entire funding_acknowledgment section to hide the accordion
# funding_acknowledgment: |
#   This work was supported by the U.S. Department of Energy, Office of Science, 
#   under Contract No. DE-XXXX-XXXXXXXXX. Additional support was provided by 
