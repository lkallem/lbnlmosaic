#   completeness, or usefulness of any information disclosed.

markdown: kramdown
highlighter: rouge
permalink: pretty

# Kramdown configuration
kramdown:
  toc_levels: 2..6  # Only include H2-H6 in table of contents
  syntax_highlighter: rouge
  syntax_highlighter_opts:
    css_class: 'highlight'
    span:
      line_numbers: false

# GitHub Pages supported plugins (automatically enabled with github-pages gem)
plugins:
  - jekyll-feed
  - jekyll-sitemap
  - jekyll-seo-tag

include: ['pages']

defaults:
  - scope:
      path: "pages"
      type: "pages"
    values:
      layout: "default"

exclude:
  - Gemfile
  - Gemfile.lock
  - README.md
  - .gitignore
  - vendor/
  - node_modules/
  - templates/
  